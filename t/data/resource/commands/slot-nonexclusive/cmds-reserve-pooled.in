# Test allocate_orelse_reserve with pooled non-exclusive SSDs: capacity is
# plentiful (4x793 GiB, 1 GiB per request), so every request -- including the
# allocate_orelse_reserve -- allocates NOW rather than reserving.  This guards
# the orelse_reserve path against regressions where pooled accounting would
# spuriously push a satisfiable request into a future reservation.
# (The reservation path itself is exercised by cmds-reserve-mixed.in.)
match allocate @TEST_SRCDIR@/data/resource/jobspecs/slot-nonexclusive/ssd-nonexclusive-limit.yaml
match allocate @TEST_SRCDIR@/data/resource/jobspecs/slot-nonexclusive/ssd-nonexclusive-limit.yaml
match allocate @TEST_SRCDIR@/data/resource/jobspecs/slot-nonexclusive/ssd-nonexclusive-limit.yaml
match allocate @TEST_SRCDIR@/data/resource/jobspecs/slot-nonexclusive/ssd-nonexclusive-limit.yaml
match allocate_orelse_reserve @TEST_SRCDIR@/data/resource/jobspecs/slot-nonexclusive/ssd-nonexclusive-limit.yaml
quit
